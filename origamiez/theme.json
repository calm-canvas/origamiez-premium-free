{
	"version": 2,
	"settings": {
		"appearanceTools": true,
		"color": {
			"palette": [
				{
					"name": "Primary",
					"slug": "primary",
					"color": "#222222"
				},
				{
					"name": "Secondary",
					"slug": "secondary",
					"color": "#f5f7fa"
				},
				{
					"name": "Heading",
					"slug": "heading",
					"color": "#222222"
				},
				{
					"name": "Body",
					"slug": "body",
					"color": "#333333"
				},
				{
					"name": "Link Hover",
					"slug": "link-hover",
					"color": "#00589f"
				},
				{
					"name": "White",
					"slug": "white",
					"color": "#ffffff"
				},
				{
					"name": "Black",
					"slug": "black",
					"color": "#000000"
				},
				{
					"name": "Metadata",
					"slug": "metadata",
					"color": "#666666"
				}
			],
			"custom": true,
			"customGradient": true,
			"defaultPalette": true,
			"link": true
		},
		"typography": {
			"customFontSize": true,
			"customFontStyle": true,
			"customFontWeight": true,
			"customLineHeight": true,
			"customTextDecoration": true,
			"customTextTransform": true,
			"fontFamilies": [
				{
					"fontFamily": "\"Georgia\", \"Times New Roman\", Times, serif",
					"name": "Serif (Body/Headings)",
					"slug": "body"
				},
				{
					"fontFamily": "\"Inter\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
					"name": "Sans-serif (UI/Menu)",
					"slug": "heading"
				}
			],
			"fontSizes": [
				{
					"name": "Small",
					"slug": "small",
					"size": "13px"
				},
				{
					"name": "Medium",
					"slug": "medium",
					"size": "15px"
				},
				{
					"name": "Large",
					"slug": "large",
					"size": "24px"
				},
				{
					"name": "X-Large",
					"slug": "x-large",
					"size": "28px"
				}
			]
		},
		"spacing": {
			"blockGap": true,
			"margin": true,
			"padding": true,
			"units": ["px", "em", "rem", "vh", "vw", "%"]
		},
		"layout": {
			"contentSize": "800px",
			"wideSize": "1140px"
		},
		"custom": {
			"typography": {
				"lineHeight": {
					"body": 1.7,
					"heading": 1.2
				},
				"fontWeight": {
					"body": 400,
					"heading": 700
				}
			}
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--white)",
			"text": "var(--wp--preset--color--body)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "var(--wp--custom--typography--line-height--body)"
		},
		"elements": {
			"heading": {
				"color": {
					"text": "var(--wp--preset--color--heading)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--body)",
					"fontWeight": "var(--wp--custom--typography--font-weight--heading)"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--primary)"
				},
				"typography": {
					"textDecoration": "none"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--link-hover)"
					}
				}
			}
		}
	}
}
